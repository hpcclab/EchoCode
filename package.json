{
  "name": "echo-code",
  "displayName": "Echo Code",
  "description": "AI-assisted speech, chat, and summaries for any language; Python lint-on-save + C++ support.",
  "version": "3.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Team-1-4910-Edward/EchoCode-Capstone-Repo.git"
  },
  "icon": "images/icon.png",
  "publisher": "EchoCode",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onSave",
    "onView:echocode.chatView",
    "onCommand:echocode.openChat",
    "onCommand:echocode.readHotkeyGuide",
    "onCommand:echocode.readErrors",
    "onCommand:echocode.annotate",
    "onCommand:echocode.readAllAnnotations",
    "onCommand:echocode.jumpToNextFunction",
    "onCommand:echocode.jumpToPreviousFunction",
    "onCommand:echocode.summarizeClass",
    "onCommand:echocode.summarizeFunction",
    "onCommand:echocode.summarizeProgram",
    "onCommand:echocode.selectMicrophone",
    "onCommand:echocode.loadAssignmentFile",
    "onCommand:echocode.increaseSpeechSpeed",
    "onCommand:echocode.decreaseSpeechSpeed",
    "onCommand:echocode.rescanUserCode",
    "onCommand:echocode.readNextSequentialTask",
    "onCommand:echocode.whereAmI",
    "onCommand:echocode.compileAndParseCpp",
    "onCommand:echocode.setGuidanceLevel",
    "onCommand:echocode.cycleGuidanceLevel"
  ],
  "main": "./extension.js",
  "extensionDependencies": [
    "ms-python.python"
  ],
  "contributes": {
    "commands": [
      {
        "command": "echocode.toggleMode",
        "title": "EchoCode: Toggle Student/Dev Mode"
      },
      {
        "command": "echocode.readHotkeyGuide",
        "title": "EchoCode: Read Hotkey Guide"
      },
      {
        "command": "echocode.readErrors",
        "title": "Read Python Errors Aloud"
      },
      {
        "command": "echocode.annotate",
        "title": "Toggle EchoCode Annotations",
        "icon": "$(comment)"
      },
      {
        "command": "echocode.readAllAnnotations",
        "title": "Read All Annotations Aloud"
      },
      {
        "command": "echocode.jumpToNextFunction",
        "title": "Jump to Next Function"
      },
      {
        "command": "echocode.jumpToPreviousFunction",
        "title": "Jump to Previous Function"
      },
      {
        "command": "echocode.summarizeClass",
        "title": "Summarize Current Class"
      },
      {
        "command": "echocode.summarizeFunction",
        "title": "Summarize Current Function"
      },
      {
        "command": "echocode.summarizeProgram",
        "title": "Summarize Current Program"
      },
      {
        "command": "echocode.openChat",
        "title": "Open EchoCode Tutor Chat"
      },
      {
        "command": "echocode.loadAssignmentFile",
        "title": "Load Assignment File"
      },
      {
        "command": "echocode.increaseSpeechSpeed",
        "title": "Increase Speech Speed"
      },
      {
        "command": "echocode.decreaseSpeechSpeed",
        "title": "Decrease Speech Speed"
      },
      {
        "command": "echocode.rescanUserCode",
        "title": "Rescan Code for Completed Tasks"
      },
      {
        "command": "echocode.readNextSequentialTask",
        "title": "Read Next Sequential Task"
      },
      {
        "command": "echocode.whereAmI",
        "title": "Where Am I?"
      },
      {
        "command": "echocode.createFile",
        "title": "Create File"
      },
      {
        "command": "echocode.createFolder",
        "title": "Create Folder"
      },
      {
        "command": "echocode.navigateToNextFile",
        "title": "Navigate to Next File"
      },
      {
        "command": "echocode.initializeFolderList",
        "title": "Initialize Folder List"
      },
      {
        "command": "echocode.moveToNextFolder",
        "title": "Move to Next Folder"
      },
      {
        "command": "echocode.switchToStudentMode",
        "title": "EchoCode: Switch to Student Mode"
      },
      {
        "command": "echocode.switchToDevMode",
        "title": "EchoCode: Switch to Developer Mode"
      },
      {
        "command": "echocode.moveToPreviousFolder",
        "title": "Move to Previous Folder"
      },
      {
        "command": "echocode.navigateFilesInCurrentFolder",
        "title": "Navigate Files in Current Folder"
      },
      {
        "command": "echocode.readCurrentLine",
        "title": "Read Current Line"
      },
      {
        "command": "echocode.describeCurrentLine",
        "title": "Describe Current Line"
      },
      {
        "command": "echocode.toggleCharacterReadOut",
        "title": "Toggle Character Read-Out"
      },
      {
        "command": "echocode.copyFileNameForImport",
        "title": "Copy File Name for Import"
      },
      {
        "command": "echocode.pasteImportAtCursor",
        "title": "Paste Import Statement at Cursor"
      },
      {
        "command": "echocode.stopSpeech",
        "title": "Stop Speech"
      },
      {
        "command": "echocode.readNextTask",
        "title": "Read Next Task"
      },
      {
        "command": "echocode.markTaskComplete",
        "title": "Mark Task Complete"
      },
      {
        "command": "echocode.speakNextAnnotation",
        "title": "Speak Next Annotation"
      },
      {
        "command": "code-tutor.analyzeBigO",
        "title": "Analyze Big O (Queue)"
      },
      {
        "command": "code-tutor.iterateBigOQueue",
        "title": "Read Next Big O Recommendation"
      },
      {
        "command": "code-tutor.readEntireBigOQueue",
        "title": "Read All Big O Recommendations"
      },
      {
        "command": "echocode.compileAndParseCpp",
        "title": "EchoCode: Compile and Parse C++ File"
      },
      {
        "command": "echocode.checkPythonErrors",
        "title": "EchoCode: Check Python Errors"
      },
      {
        "command": "echocode.selectMicrophone",
        "title": "EchoCode: Select Microphone",
        "category": "EchoCode Voice"
      },
      {
        "command": "echocode.toggleVoice",
        "title": "EchoCode: Toggle Voice Input",
        "category": "EchoCode Voice"
      },
      {
        "command": "echocode.voiceCode",
        "title": "EchoCode: Voice to Code",
        "category": "EchoCode Voice"
      },
      {
        "command": "echocode.voiceCommand",
        "title": "EchoCode: Voice to Command",
        "category": "EchoCode Voice"
      },
      {
        "command": "echocode.voiceChat",
        "title": "EchoCode: Voice to Chat",
        "category": "EchoCode Voice"
      },
      {
        "command": "echocode.cycleVoiceMode",
        "title": "EchoCode: Cycle Voice Mode",
        "category": "EchoCode Voice"
      },
      {
        "command": "echocode.setGuidanceLevel",
        "title": "EchoCode: Set Guidance Level"
      },
      {
        "command": "echocode.cycleGuidanceLevel",
        "title": "EchoCode: Cycle Guidance Level"
      }
    ],
    "configuration": {
      "title": "EchoCode",
      "properties": {
        "echocode.mode": {
          "type": "string",
          "enum": [
            "student",
            "dev"
          ],
          "default": "student",
          "description": "Student mode locks restricted features. Dev mode enables everything."
        },
        "echocode.voice": {
          "type": "string",
          "default": "",
          "description": "Voice name for text-to-speech. Leave blank for system default."
        },
        "echocode.rate": {
          "type": "number",
          "default": 1,
          "description": "Speech rate for text-to-speech (0.5 = slow, 1.0 = normal, 1.5 = fast)."
        },
        "echocode.guidanceLevel": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "guided",
            "balanced",
            "concise"
          ],
          "enumDescriptions": [
            "Step-by-step explanations with minimal jargon.",
            "Balanced explanations with brief rules and a couple options.",
            "Concise, technical output with the raw error included."
          ],
          "description": "Controls how much detail EchoCode provides when explaining errors."
        }
      }
    },
    "keybindings": [
      {
        "command": "echocode.toggleMode",
        "key": "ctrl+alt+9",
        "when": "true"
      },
      {
        "key": "f1",
        "command": "echocode.readHotkeyGuide",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.speakNextAnnotation",
        "key": "ctrl+alt+s"
      },
      {
        "command": "echocode.annotate",
        "key": "ctrl+alt+a"
      },
      {
        "command": "echocode.readAllAnnotations",
        "key": "ctrl+alt+q"
      },
      {
        "command": "echocode.jumpToNextFunction",
        "key": "ctrl+alt+down",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.jumpToPreviousFunction",
        "key": "ctrl+alt+up",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.summarizeClass",
        "key": "ctrl+alt+e c",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "echocode.summarizeFunction",
        "key": "ctrl+alt+e f",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "echocode.summarizeProgram",
        "key": "ctrl+alt+e p",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "echocode.toggleVoice",
        "key": "ctrl+alt+space",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.toggleVoice",
        "key": "ctrl+alt+space",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.voiceCode",
        "key": "ctrl+alt+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.voiceCommand",
        "key": "ctrl+alt+shift+v"
      },
      {
        "command": "echocode.voiceChat",
        "key": "ctrl+alt+shift+t"
      },
      {
        "command": "echocode.cycleVoiceMode",
        "key": "ctrl+alt+'"
      },
      {
        "command": "echocode.openChat",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "code-tutor.analyzeBigO",
        "key": "ctrl+alt+n",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "echocode.whereAmI",
        "key": "ctrl+alt+e w",
        "when": "editorTextFocus"
      },
      {
        "command": "code-tutor.iterateBigOQueue",
        "key": "ctrl+alt+b",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "code-tutor.readEntireBigOQueue",
        "key": "ctrl+alt+h",
        "when": "echocode:isDev"
      },
      {
        "key": "ctrl+alt+o",
        "command": "echocode.loadAssignmentFile",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+alt+x",
        "command": "echocode.stopSpeech"
      },
      {
        "key": "ctrl+alt+u",
        "command": "echocode.increaseSpeechSpeed",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+alt+d",
        "command": "echocode.decreaseSpeechSpeed",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.rescanUserCode",
        "key": "ctrl+alt+y",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.readNextSequentialTask",
        "key": "ctrl+alt+/",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.readNextTask",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.markTaskComplete",
        "key": "ctrl+alt+m",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.createFile",
        "key": "ctrl+alt+;",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.createFolder",
        "key": "ctrl+alt+f",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.navigateToNextFile",
        "key": "ctrl+alt+p"
      },
      {
        "command": "echocode.moveToNextFolder",
        "key": "ctrl+alt+["
      },
      {
        "command": "echocode.moveToPreviousFolder",
        "key": "ctrl+alt+]"
      },
      {
        "command": "echocode.initializeFolderList",
        "title": "Initialize Folder List"
      },
      {
        "command": "echocode.readCurrentLine",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.describeCurrentLine",
        "key": "ctrl+alt+k",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "command": "echocode.toggleCharacterReadOut",
        "key": "ctrl+alt+r",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+alt+i",
        "command": "echocode.copyFileNameForImport",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "key": "ctrl+shift+i",
        "command": "echocode.pasteImportAtCursor",
        "when": "editorTextFocus && echocode:isDev"
      },
      {
        "key": "ctrl+alt+g",
        "command": "echocode.compileAndParseCpp",
        "when": "editorTextFocus && editorLangId == 'cpp' && echocode:isDev"
      },
      {
        "key": "ctrl+alt+g",
        "command": "echocode.checkPythonErrors",
        "when": "editorTextFocus && editorLangId == 'python' && echocode:isDev"
      },
      {
        "command": "echocode.setGuidanceLevel",
        "key": "ctrl+alt+shift+z",
        "when": "editorTextFocus"
      },
      {
        "command": "echocode.cycleGuidanceLevel",
        "key": "ctrl+alt+z",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "echocode",
          "title": "EchoCode",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "echocode": [
        {
          "id": "echocode.chatView",
          "name": "EchoCode Tutor",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "echocode.annotate",
          "when": "echocode:isDev",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint-python": "pylint **/*.py",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint",
    "test": "node --loader ./test/alias-loader.mjs ./node_modules/mocha/bin/_mocha --require ts-node/register --require test/setup.mjs --recursive test/**/*.test.ts --timeout 10000",
    "int-test": "npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6.2.0",
    "eslint": "^9.24.0",
    "glob": "^10.3.10",
    "mocha": "^10.8.2",
    "nyc": "^17.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.33",
    "axios": "^1.8.3",
    "dotenv": "^16.6.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "mammoth": "^1.9.0",
    "mic": "^2.1.2",
    "openai": "^5.20.0",
    "pdf-parse": "^1.1.1",
    "say": "^0.16.0",
    "sound-play": "^1.1.0",
    "uuid": "^13.0.0"
  }
}
